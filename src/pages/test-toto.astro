---
import Base from '../layouts/Base.astro';

const title = 'Toto le Rigolo - Page de test';
const description = 'Page de test pour vérifier le déploiement Cloudflare Pages.';
---

<Base title={title} description={description}>
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100">
    <div class="max-w-2xl mx-auto px-6 py-16 text-center">
      <h1 class="text-5xl font-bold text-indigo-700 mb-6">Toto le Rigolo</h1>
      <p class="text-xl text-gray-700 leading-relaxed mb-8">
        Toto demande a son professeur : "Monsieur, est-ce qu'on peut etre puni pour quelque chose qu'on n'a pas fait ?"
        Le professeur repond : "Non, bien sur que non !"
        Toto : "Ouf, parce que je n'ai pas fait mes devoirs."
      </p>
      <p class="text-lg text-gray-500 italic">
        Cette page est un test de deploiement. Si vous la voyez, c'est que tout fonctionne parfaitement !
      </p>
      <div class="mt-10">
        <a href="/" class="inline-block px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
          Retour a l'accueil
        </a>
      </div>
    </div>
  </main>
</Base>
