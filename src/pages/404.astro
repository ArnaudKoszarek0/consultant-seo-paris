---
import Base from '../layouts/Base.astro';
---

<Base
  title="Page introuvable - Consultant SEO Paris"
  description="La page que vous recherchez n'existe pas ou a été déplacée."
>
  <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <p class="text-6xl font-bold text-emerald-500 mb-4">404</p>
    <h1 class="text-3xl md:text-4xl font-bold mb-4">Page introuvable</h1>
    <p class="text-gray-600 text-lg mb-10">
      La page que vous recherchez n'existe pas ou a été déplacée.
    </p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/" class="bg-emerald-500 text-white px-7 py-3 rounded-lg hover:bg-emerald-600 transition font-medium">
        Retour à l'accueil
      </a>
      <a href="/blog/" class="border border-emerald-400 text-emerald-600 px-7 py-3 rounded-lg hover:bg-emerald-50 transition font-medium">
        Lire le blog
      </a>
      <a href="/contact/" class="border border-gray-200 text-gray-600 px-7 py-3 rounded-lg hover:bg-gray-50 transition font-medium">
        Me contacter
      </a>
    </div>
  </section>
</Base>
